# 필수 - 없으면 뉴스 기능 미작동
NEWS_API_KEY=your_newsapi_key_here

# 선택 - 없어도 기본 데이터 작동 (제한적)
FRED_API_KEY=your_fred_api_key_here

# 필수 - Gemini AI 기능 전체 (가이던스 분석, 번역, 경쟁사 선정, 심층 리서치)
# https://aistudio.google.com 에서 무료 발급
# 주의: GOOGLE_API_KEY는 두지 말 것. google-genai SDK가 이 값을 자동 우선하여
#       엉뚱한(폐기된) 키로 호출될 수 있음. GEMINI_API_KEY만 사용한다.
GEMINI_API_KEY=your_gemini_api_key_here

# 필수 - ingest2 수집/시장데이터
POLYGON_API_KEY=your_polygon_api_key_here

# 선택 - 없으면 실적 발표 시뮬레이터 비활성화 (https://finnhub.io 에서 무료 발급)
FINNHUB_API_KEY=your_finnhub_api_key_here

# 선택 - 심층 리서치 검색 품질 향상
TAVILY_API_KEY=your_tavily_key_here
PARALLEL_API_KEY=your_parallel_key_here
