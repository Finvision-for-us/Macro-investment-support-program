# Required for Gemini execution
GEMINI_API_KEY=

# Grounded mode default model
GEMINI_GROUNDED_MODEL=gemini-2.5-pro

# Deep Research mode default agent
GEMINI_DEEP_RESEARCH_AGENT=deep-research-preview-04-2026

# Optional: Langfuse upload
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
