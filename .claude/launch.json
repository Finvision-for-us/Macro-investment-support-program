{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "FinVision Frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "5173"],
      "cwd": "frontend",
      "port": 5173,
      "autoPort": false
    },
    {
      "name": "FinVision Backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--reload", "--port", "8000"],
      "cwd": "backend",
      "port": 8000
    },
    {
      "name": "FinVision UI",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/next/dist/bin/next", "dev", "--port", "3000"],
      "cwd": "ui",
      "port": 3000,
      "autoPort": false
    }
  ]
}
